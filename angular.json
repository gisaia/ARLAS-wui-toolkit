{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "cli": {
    "analytics": false,
    "cache": {
      "enabled": false
    }
  },
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "arlas-wui-toolkit-demo": {
      "root": "",
      "sourceRoot": "src",
      "projectType": "application",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist"
            },
            "index": "src/index.html",
            "tsConfig": "src/tsconfig.app.json",
            "polyfills": [
              "src/polyfills.ts"
            ],
            "assets": [
              "src/assets",
              "src/i18n",
              "src/favicon.ico",
              "src/config.json",
              "src/settings.yaml",
              "src/silent-refresh.html",
              "src/tour.json",
              "src/env.js"
            ],
            "styles": [
              "src/styles.css",
              "node_modules/arlas-web-components/assets/styles.css"
            ],
            "scripts": [],
            "browser": "src/main.ts"
          },
          "configurations": {
            "development": {
              "optimization": false,
              "outputHashing": "all",
              "sourceMap": true,
              "namedChunks": true,
              "extractLicenses": false,
              "budgets": []
            },
            "production": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "arlas-wui-toolkit:build"
          },
          "configurations": {
            "development": {
              "buildTarget": "arlas-wui-toolkit-demo:build:development"
            },
            "production": {
              "buildTarget": "arlas-wui-toolkit-demo:build:production"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "arlas-wui-toolkit-demo:build"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "watch": false,
            "tsConfig": "src/tsconfig.spec.json"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "eslintConfig": "eslint.config.mjs",
            "lintFilePatterns": [
              "src/**/*.spec.ts",
              "src/**/*.d.ts",
              "src/**/*.ts"
            ]
          }
        }
      }
    },
    "arlas-wui-toolkit": {
      "projectType": "library",
      "root": "projects/arlas-toolkit",
      "sourceRoot": "projects/arlas-toolkit/src",
      "prefix": "arlas",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "tsConfig": "projects/arlas-toolkit/tsconfig.lib.json",
            "project": "projects/arlas-toolkit/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/arlas-toolkit/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/arlas-toolkit/tsconfig.lib.json"
            }
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "watch": false,
            "tsConfig": "projects/arlas-toolkit/tsconfig.spec.json"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "eslintConfig": "eslint.config.mjs",
            "lintFilePatterns": [
              "projects/**/*.spec.ts",
              "projects/**/*.d.ts",
              "projects/**/*.ts"
            ]
          }
        }
      }
    }
  },
  "schematics": {
    "@schematics/angular:component": {
      "prefix": "arlas",
      "style": "scss"
    },
    "@schematics/angular:directive": {
      "prefix": "arlas"
    },
    "@angular-eslint/schematics:application": {
      "setParserOptionsProject": true
    },
    "@angular-eslint/schematics:library": {
      "setParserOptionsProject": true
    }
  }
}
